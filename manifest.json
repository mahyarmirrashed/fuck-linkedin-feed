{
  "manifest_version": 3,
  "name": "Fuck LinkedIn's Feed",
  "version": "1.0.0",
  "description": "Removes the LinkedIn feed.",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://*.linkedin.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "fuck-linkedin-feed@local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
